#!/usr/bin/env groovy

@Library('jenkins-shared-library') _

pipeline {
	agent {
		label params.NODE_LABEL_MOBILE
	}
	parameters {
		string(name: 'NODE_LABEL_MOBILE', defaultValue: 'macos-latest', description: 'Mac node label')
	}
	options {
		ansiColor('xterm')
		disableConcurrentBuilds(abortPrevious: true)
		skipStagesAfterUnstable()
	}
	stages {
		stage('Setup') {
			steps {
				setupHomebrew()
				setupAsdf()
				setupAndroid()
			}
		}
		stage('Mac Tests') {
			steps {
				checkHomebrew()
				checkAsdf(
					plugins: [
						"awscli",
						"java",
						"nodejs",
						"python",
						"ruby",
						"terraform"
					]
				)
				checkAndroid()
			}
		}
	}
}
